{
  "name": "use-local-llm",
  "version": "0.1.0",
  "description": "React hooks for streaming responses from local LLMs — Ollama, LM Studio, llama.cpp. Zero server required.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test:live": "npx tsx scripts/test-live.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "llm",
    "ollama",
    "lm-studio",
    "llama-cpp",
    "streaming",
    "local-ai",
    "local-llm",
    "typescript",
    "ai",
    "chat",
    "inference"
  ],
  "author": "pooyagolchian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pooyagolchian/use-local-llm"
  },
  "homepage": "https://github.com/pooyagolchian/use-local-llm#readme",
  "bugs": {
    "url": "https://github.com/pooyagolchian/use-local-llm/issues"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "sideEffects": false
}
